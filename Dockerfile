# =====================================================
# IMAGEM BASE NODE.JS
# =====================================================

# Usa Node.js oficial
FROM node:20-alpine

# =====================================================
# DIRETÓRIO DA APLICAÇÃO
# =====================================================

# Define pasta de trabalho
WORKDIR /app

# =====================================================
# INSTALA DEPENDÊNCIAS
# =====================================================

# Copia package.json
COPY package*.json ./

# Instala dependências
RUN npm install

# =====================================================
# COPIA PROJETO
# =====================================================

# Copia todos os arquivos
COPY . .

# =====================================================
# BUILD DO NEXT.JS
# =====================================================

# Gera build de produção
RUN npm run build

# =====================================================
# PORTA DA APLICAÇÃO
# =====================================================

# Porta padrão do Next.js
EXPOSE 3000

# =====================================================
# INICIA APLICAÇÃO
# =====================================================

# Inicia Next.js em produção
CMD ["npm", "start"]